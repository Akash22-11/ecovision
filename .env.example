# Copy this file to `.env` and fill in real values for local/production use.

# --- App ---
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Security / JWT ---
SECRET_KEY=replace_with_a_long_random_secret_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
# Used directly by the app, and by docker-compose to provision the postgres service.
POSTGRES_USER=ecovision
POSTGRES_PASSWORD=ecovision
POSTGRES_DB=ecovision_ai
DATABASE_URL=postgresql+psycopg2://ecovision:ecovision@db:5432/ecovision_ai

# --- CORS ---
# Comma-separated list of allowed origins, or * for all (development only).
CORS_ORIGINS=*

# --- YOLOv8 ---
# Point this at a YOLOv8 model fine-tuned on pollution classes
# (smoke, dust, garbage_burning, construction_dust, industrial_smoke).
# If the file doesn't exist, the API runs pollution detection in mock mode.
YOLO_MODEL_PATH=ml/pollution_yolov8.pt
YOLO_CONFIDENCE_THRESHOLD=0.35

# --- AQI prediction model ---
AQI_MODEL_PATH=ml/model.pkl

# --- OpenWeather ---
# Get a free key at https://openweathermap.org/api
# If left blank, /weather/current returns deterministic mock readings.
OPENWEATHER_API_KEY=
